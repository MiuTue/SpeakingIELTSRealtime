generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PracticeMode {
  PART1
  PART2
  PART3
  FULL_TEST
  CUSTOM
}

enum SpeakingPart {
  PART1
  PART2
  PART3
}

enum SessionStatus {
  ACTIVE
  PAUSED
  SCORING
  COMPLETED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
}

enum MobilePlatform {
  IOS
  ANDROID
}

enum TurnSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum AudioUploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
  EXPIRED
}

enum EvaluationJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id             String            @id @default(cuid())
  name           String
  email          String            @unique
  emailVerified  Boolean           @default(false)
  image          String?
  role           UserRole          @default(USER)
  targetBand     Float             @default(7)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt
  accounts       Account[]
  authSessions   Session[]
  sessions       SpeakingSession[]
  progress       UserProgress?
  mobileDevices  MobileDevice[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([identifier])
}

model SpeakingSession {
  id              String         @id @default(cuid())
  userId          String
  mode            PracticeMode
  topic           String
  targetBand      Float
  voice           String         @default("Aoede")
  startedAt       DateTime       @default(now())
  endedAt         DateTime?
  finalBand       Float?
  durationSeconds Int            @default(0)
  status          SessionStatus  @default(ACTIVE)
  checkpointJson  Json?
  pausedAt        DateTime?
  resumedAt       DateTime?
  version         Int            @default(1)
  user            User           @relation(fields: [userId], references: [id])
  turns           SpeakingTurn[]
  audioAssets     AudioAsset[]
  evaluationJobs  EvaluationJob[]

  @@index([userId, startedAt])
  @@index([userId, status])
}

model SpeakingTurn {
  id              String          @id @default(cuid())
  sessionId       String
  part            SpeakingPart
  question        String
  transcript      String
  durationSeconds Int             @default(0)
  estimatedBand   Float?
  feedbackJson    Json?
  audioUrl        String?
  clientTurnId    String?
  sequence        Int             @default(0)
  syncStatus      TurnSyncStatus  @default(SYNCED)
  createdAt       DateTime        @default(now())
  session         SpeakingSession @relation(fields: [sessionId], references: [id])
  audioAssets     AudioAsset[]

  @@index([sessionId, createdAt])
  @@unique([sessionId, clientTurnId])
}

model UserProgress {
  id                    String   @id @default(cuid())
  userId                String   @unique
  avgBand               Float    @default(0)
  fluencyAvg            Float    @default(0)
  lexicalAvg            Float    @default(0)
  grammarAvg            Float    @default(0)
  pronunciationAvg      Float    @default(0)
  totalSessions         Int      @default(0)
  totalSpeakingMinutes  Float    @default(0)
  updatedAt             DateTime @default(now()) @updatedAt
  user                  User     @relation(fields: [userId], references: [id])
}

model MobileDevice {
  id             String         @id @default(cuid())
  userId         String
  installationId String
  platform       MobilePlatform
  appVersion     String
  deviceName     String?
  lastActiveAt   DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, installationId])
  @@index([userId, lastActiveAt])
}

model AudioAsset {
  id          String            @id @default(cuid())
  sessionId   String
  turnId      String?
  storagePath String            @unique
  contentType String
  byteCount   Int?
  status      AudioUploadStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  session     SpeakingSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  turn        SpeakingTurn?     @relation(fields: [turnId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@index([expiresAt, status])
}

model EvaluationJob {
  id             String              @id @default(cuid())
  sessionId      String
  idempotencyKey String
  status         EvaluationJobStatus @default(QUEUED)
  attemptCount   Int                 @default(0)
  feedbackJson   Json?
  errorCode      String?
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt
  session        SpeakingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, idempotencyKey])
  @@index([sessionId, createdAt])
  @@index([status, createdAt])
}
