# Web and Railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/speakielts_ai"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Gemini
GEMINI_API_KEY=""
GEMINI_EVALUATOR_MODEL="gemini-2.5-flash-lite"

# Server-side audio storage
# Local: keep this relative. Railway: mount a Volume to /app/.data/audio.
AUDIO_STORAGE_DIR=".data/audio"
AUDIO_UPLOAD_SECRET="replace-with-at-least-32-random-characters"

# Mobile release controls
MOBILE_MINIMUM_VERSION="1.0.0"
MOBILE_LATEST_VERSION="1.0.0"
MOBILE_FORCE_UPDATE="false"
MOBILE_MAINTENANCE="false"

# Expo mobile: place this in mobile/.env for local development.
# Use your Mac LAN address when testing on a physical iPhone.
EXPO_PUBLIC_API_URL="http://192.168.1.10:3000"
